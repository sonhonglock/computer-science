#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>
#define MAX_SIZE 200003
#include <string.h>

typedef struct queue
{
    int arr[MAX_SIZE];
    int front;
    int rear;
    int count;
}queue;

typedef struct info
{
    int isqueue;
    int data;
}info;

void queueinit(queue* q)
{
    q->front = 0;
    q->rear = 0;
    q->count = 0;
}

int isempty(queue* q)
{
    return (q->count == 0);
}

int isfull(queue* q)
{
    return (q->count == MAX_SIZE);
}

void enqueue(queue* q,int data)
{
    if (isfull(q)) return;

    q->arr[(q->rear)++] = data;
    q->rear %= MAX_SIZE;
    q->count++;
}

int dequeue(queue* q)
{
    if (isempty(q)) return -999999;

    int data = q->arr[(q->front)++];
    q->front %= MAX_SIZE;
    q->count--;

    return data;
}

int main(){
    int N,M;
    scanf("%d",&N);
    info check[N];
    int a;
    for (int i=0;i<N;i++)       //큐 어딨는지 찾아야함//
    {
        scanf("%d",&a);
        if (a==0)
        {
            check[i].isqueue = 1;
        }
        else{
            check[i].isqueue = 0;
        }
    }

    queue q;
    queueinit(&q);
    
    for (int i=0;i<N;i++)       //입력 받음//
    {
        scanf("%d",&(check[i].data));
    }

    for (int i=N;i>=0;i--)    // 스택은 건너뛰고 기존 큐에 있는 데이터들만 역순으로 하나의 큐에 대입//
    {
        if (check[i].isqueue == 1) enqueue(&q,check[i].data);
    }

    scanf("%d",&M);
    int b;
    for (int i=0;i<M;i++)
    {
        scanf("%d",&b);
        enqueue(&q,b);
    }

    for (int i=1;i<M;i++)
    {
        printf("%d ",dequeue(&q));
    }
    printf("%d",dequeue(&q));
}

